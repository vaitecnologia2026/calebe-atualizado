{
  "name": "crm-calebe-afiliados",
  "version": "0.1.0",
  "private": true,
  "description": "CRM Imobiliário de Corretores Afiliados — Calebe Investimentos Imobiliários",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "webhook:test": "curl -X POST http://localhost:3000/api/webhooks/leads -H 'Content-Type: application/json' -H \"X-Webhook-Signature: $(node -e \"console.log(require('crypto').createHmac('sha256', process.env.WEBHOOK_LEADS_SECRET).update(process.argv[1]).digest('hex'))\" '{\\\"source\\\":\\\"test\\\",\\\"name\\\":\\\"Maria Teste\\\",\\\"phone\\\":\\\"47999990000\\\",\\\"campaign\\\":\\\"manual\\\"}')\" -d '{\"source\":\"test\",\"name\":\"Maria Teste\",\"phone\":\"47999990000\",\"campaign\":\"manual\"}'",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^0.27.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "14.2.20",
    "next-auth": "5.0.0-beta.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
