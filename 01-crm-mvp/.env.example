# =============================================================================
# CRM CALEBE AFILIADOS — Variáveis de Ambiente (MVP)
# =============================================================================
# Copie para .env.local (dev) ou configure em Vercel → Project → Settings → Environment Variables
# -----------------------------------------------------------------------------

# --- Database (Postgres via Neon, Supabase ou Vercel Postgres) ---------------
# Formato: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/crm_calebe?sslmode=require"
# DIRECT_URL é usado pelo Prisma migrate (bypass pooler) — obrigatório com Neon/Supabase
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/crm_calebe?sslmode=require"

# --- Auth (NextAuth v5) ------------------------------------------------------
# Gere com: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_32_BYTES_BASE64"
# Em produção Vercel não é necessário, setar apenas se domínio custom
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- Criptografia de dados sensíveis (telefones de leads, dados de clientes) -
# Gere com: openssl rand -base64 32
DATA_ENCRYPTION_KEY="CHANGE_ME_32_BYTES_BASE64"

# --- Storage (Vercel Blob) ---------------------------------------------------
# Criar em Vercel → Storage → Blob → gerar Read/Write Token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXX"

# --- Chat tempo real (Pusher Channels) ---------------------------------------
# https://pusher.com → Channels → App Keys
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# --- VAI API (CRM + WhatsApp) — integração oficial ---------------------------
# Documentação oficial: https://api.vaicrm.com.br/docs#
VAI_API_BASE_URL="https://api.vaicrm.com.br"
VAI_API_TOKEN=""
VAI_INSTANCE_ID=""
VAI_SENDER_PHONE=""
# HMAC secret para validar webhooks de inbound da VAI em /api/webhooks/vai
VAI_WEBHOOK_SECRET=""

# --- Webhook receiver de LEADS (ads externos, formulários, parceiros) --------
# HMAC-SHA256 do body usando este secret em header X-Webhook-Signature
# Endpoint: POST /api/webhooks/leads
WEBHOOK_LEADS_SECRET=""

# --- App config --------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="CRM Calebe Afiliados"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="Calebe Investimentos Imobiliários"
# URL pública do vídeo de boas-vindas (ex.: Vimeo/YouTube privado ou Vercel Blob)
NEXT_PUBLIC_ONBOARDING_VIDEO_URL=""

# --- Limites e regras padrão (podem ser sobrescritos em system_settings) -----
LEAD_QUOTA_BRONZE=1
LEAD_QUOTA_SILVER=2
LEAD_QUOTA_GOLD=3
LEAD_QUOTA_DIAMOND=5

# --- Senha inicial (seed) — trocar após primeiro login -----------------------
# Aplicada nos 4 usuários oficiais: adm@calebe.com.br, corretor@calebe.com.br,
# juridico@calebe.com.br, secretaria@calebe.com.br
SEED_DEFAULT_PASSWORD="Calebe@2026!"

# --- Integração futura (deixado preparado) -----------------------------------
# CRECI_API_BASE_URL=""
# CRECI_API_TOKEN=""

# =============================================================================
# TRACKEAMENTO (Padrão VAI) — Facebook Pixel + Google Analytics 4 + GTM
# =============================================================================
# Deixe vazio para desabilitar. Os scripts só carregam se o respectivo ID existir.
# Eventos disparados automaticamente:
#   - PageView (carregamento)
#   - cta_click (botões com data-cta)
#   - generate_lead / Lead (envio do cadastro de corretor)
#   - form_submit (qualquer formulário)
#   - login, sign_up, purchase (quando aplicável)

# Google Analytics 4 — https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=""

# Facebook/Meta Pixel — https://business.facebook.com → Events Manager
NEXT_PUBLIC_FB_PIXEL_ID=""

# Google Tag Manager — https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID=""
